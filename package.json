{
  "name": "quicktds",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MCP server for TDS credit reconciliation and recovery workflows",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:nitro": "nitrostack-cli dev",
    "build:server": "tsc",
    "inspector": "npm run build:server && npx --yes @modelcontextprotocol/inspector -e MCP_TRANSPORT_TYPE=stdio -e NODE_ENV=development node dist/index.js",
    "build": "nitrostack-cli build && node scripts/inline-widget-css.mjs",
    "start": "npm run build && nitrostack-cli start",
    "start:prod": "nitrostack-cli start",
    "test": "npx tsc && node --test test/*.test.mjs",
    "upgrade": "nitrostack-cli upgrade",
    "install:all": "nitrostack-cli install",
    "widget": "npm --prefix src/widgets"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nitrostack/core": "^1.0.13",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "@modelcontextprotocol/ext-apps": ">=0.1.0"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1.0.14",
    "@types/node": "^22.10.0",
    "typescript": "^5.3.3"
  },
  "author": "",
  "nitrostack": {
    "skillsVersion": "1.0.0"
  }
}
